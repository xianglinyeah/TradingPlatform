{
  "uid": "hft-paper-trading",
  "title": "HFT Paper Trading — PnL & Slippage",
  "description": "Sim-fill analytics for the Java md/strategy pipeline. Sources: hft.* in ClickHouse (JSONL runs imported by scripts/reporting/import_runs.ps1, md by MdTopExporter). All time axes are md-stream time (fill clock), comparable across live and backtest runs.",
  "tags": ["trading", "paper", "clickhouse"],
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "run",
        "label": "Run",
        "type": "query",
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
        "query": {
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT DISTINCT runId FROM hft.sim_fills ORDER BY runId",
          "refId": "variable"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Equity curve (net PnL, USD)",
      "description": "cash + position marked at latest fill price, cumulated per run. Fees included.",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "stepAfter",
            "spanNulls": true,
            "pointSize": 4,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, runId, argMax(runPnlUsd, fillId) AS runPnlUsd FROM hft.v_equity_curve WHERE runId IN (${run:singlequote}) AND $__timeFilter(ts) GROUP BY ts, runId ORDER BY ts"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Run summary",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT runId AS run, round(argMax(runPnlUsd, (ts, fillId)), 2) AS \"net PnL $\", round(max(runFeesUsd), 2) AS \"fees $\", round(argMax(runPnlUsd, (ts, fillId)) + max(runFeesUsd), 2) AS \"gross $\", count() AS fills FROM hft.v_equity_curve WHERE runId IN (${run:singlequote}) GROUP BY runId ORDER BY runId"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cumulative fees (USD)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "stepAfter",
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, runId, argMax(runFeesUsd, fillId) AS runFeesUsd FROM hft.v_equity_curve WHERE runId IN (${run:singlequote}) AND $__timeFilter(ts) GROUP BY ts, runId ORDER BY ts"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Position (base units)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "stepAfter",
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(runId, ' ', venue, ' ', product) AS series, posAfter FROM hft.v_fills WHERE runId IN (${run:singlequote}) AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Slippage by product (vs mid at fill time)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT venue, product, count() AS fills, round(avg(slipBps), 3) AS \"avg bps\", round(quantile(0.5)(slipBps), 3) AS \"p50 bps\", round(quantile(0.95)(slipBps), 3) AS \"p95 bps\", round(max(slipBps), 3) AS \"max bps\" FROM hft.v_slippage WHERE runId IN (${run:singlequote}) GROUP BY venue, product ORDER BY venue, product"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Slippage per fill (bps)",
      "description": "Side-adjusted vs mid at fill (stream) time. Positive = filled worse than mid.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, slipBps FROM hft.v_slippage WHERE runId IN (${run:singlequote}) AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Arb basis deviation at signal (bps)",
      "description": "devBps/emaBps from arb orders. Caveat: orders carry decision wall-clock time — for backtest runs these points sit at replay time, not stream time.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(ifNull(symbol, ''), ' dev') AS series, devBps FROM hft.orders WHERE runId IN (${run:singlequote}) AND isNotNull(devBps) AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "BTC mid (top-of-book)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "stepAfter",
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, mid FROM hft.md_top WHERE product LIKE 'BTC%' AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "ETH mid (top-of-book)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "lineInterpolation": "stepAfter",
            "spanNulls": true,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, mid FROM hft.md_top WHERE product LIKE 'ETH%' AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    }
  ]
}
