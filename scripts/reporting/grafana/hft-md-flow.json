{
  "uid": "hft-md-flow",
  "title": "HFT Market Data Flow",
  "description": "Market data stream health from queue replay: throughput, sequence gaps, snapshot reloads, spreads, and coverage. Sourced from hft.md_stats (per-second) and hft.md_top (per price change).",
  "tags": ["trading", "marketdata", "clickhouse"],
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sequence gaps (range total, must be 0)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT sum(seqGaps) AS gaps FROM hft.md_stats WHERE $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Snapshot reloads (range total)",
      "description": "Each snapshot after the first per session means a STALE→recovery cycle.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT sum(snapshots) AS snapshots FROM hft.md_stats WHERE $__timeFilter(ts)"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Stream coverage & freshness",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "table",
          "format": 1,
          "rawSql": "SELECT venue, product, min(ts) AS first, max(ts) AS last, round(dateDiff('minute', max(ts), now()) / 60.0, 1) AS \"age h\", count() AS \"active secs\", sum(docs) AS totalDocs, round(totalDocs / count(), 1) AS \"docs/s\", sum(seqGaps) AS gaps, sum(snapshots) AS snaps FROM hft.md_stats GROUP BY venue, product ORDER BY venue, product"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Docs per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 1, "spanNulls": false, "showPoints": "auto", "pointSize": 3 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, docs FROM hft.md_stats WHERE $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Levels per second (book update volume)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 1, "spanNulls": false, "showPoints": "auto", "pointSize": 3 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, levels FROM hft.md_stats WHERE $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Snapshot reloads over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "points", "pointSize": 6, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, snapshots FROM hft.md_stats WHERE snapshots > 0 AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "BTC spread (bps)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 1, "lineInterpolation": "stepAfter", "spanNulls": true, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, (bestAsk - bestBid) / mid * 1e4 AS spreadBps FROM hft.md_top WHERE product LIKE 'BTC%' AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "ETH spread (bps)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 1, "lineInterpolation": "stepAfter", "spanNulls": true, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "editorType": "sql",
          "queryType": "timeseries",
          "format": 0,
          "rawSql": "SELECT ts, concat(venue, ' ', product) AS series, (bestAsk - bestBid) / mid * 1e4 AS spreadBps FROM hft.md_top WHERE product LIKE 'ETH%' AND $__timeFilter(ts) ORDER BY ts"
        }
      ]
    }
  ]
}
