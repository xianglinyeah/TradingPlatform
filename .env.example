# TradingPlatform environment variable template
# Copy to .env (or set in shell) and modify as needed.
# Never commit the real .env file.

# ==================== Secrets ====================
# GM (myquant.cn) SDK token - required by data-ingestion, market-data-gm, execution-adapter-gm
GM_TOKEN=

# GM account IDs - used by execution-adapter-gm (config.yaml) and Execution.Service (appsettings.json)
# In Execution.Service, set via env var GM__PaperAccountId (ASP.NET Core __ separator overrides JSON)
GM_PAPER_ACCOUNT_ID=
GM_LIVE_ACCOUNT_ID=

# Grafana admin password (override the dev default in infra/k8s/services/grafana.yaml)
GF_SECURITY_ADMIN_PASSWORD=

# PostgreSQL credentials (dev defaults shown; override for production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dev
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_pass

# ClickHouse credentials
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=dev_user
CLICKHOUSE_PASSWORD=dev_pass

# ==================== Risk manager ====================
# Set to "true" to enforce risk checks in Execution.Service.
# When "false" (default for dev), all orders bypass fund/position validation.
RISK_CHECK_ENABLED=false

# ==================== Kafka ====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_MARKET_DATA_TOPIC=market.data
KAFKA_REPLAY_CONTROL_TOPIC=replay.control

# ==================== Execution Service ====================
# Mode: SIMULATION, PAPER_BROKER, LIVE_BROKER
EXECUTION_MODE=SIMULATION
EXECUTION_SERVICE_ADDRESS=localhost:8084

# ==================== Strategy Engine ====================
STRATEGY_INITIAL_CAPITAL=1000000
STRATEGY_COMMISSION_RATE=0.0003
KAFKA_GROUP_ID=strategy_engine_group

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_PATH=D:/TradingPlatform/logs

# ==================== Data paths ====================
DATA_BASE_PATH=D:/TradingPlatform/data
PARQUET_PATH=D:/TradingPlatform/data/minute/1min
