<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="azure.cn" value="https://nuget.azure.cn/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageRestore>
    <add key="enableRestore" value="True" />
    <add key="useParallelRestore" value="True" />
  </packageRestore>
  <bindingRedirects>
    <add key="skip" value="False" />
  </bindingRedirects>
</configuration>