# strategy_engine environment variable configuration template
# Copy this file to .env and modify as needed.

# Kafka configuration (overridden by environment variables)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=market.data
KAFKA_GROUP_ID=strategy_engine_group

# Data storage configuration (overridden by environment variables)
DATA_BASE_PATH=D:\TradingPlatform\data
PARQUET_PATH=D:\TradingPlatform\data\minute\1min

# ExecutionService configuration
EXECUTION_SERVICE_ADDRESS=localhost:8084

# Strategy configuration (overridden by environment variables)
INITIAL_CAPITAL=1000000
COMMISSION_RATE=0.0003

# Logging configuration (overridden by environment variables)
LOG_LEVEL=INFO
LOG_PATH=D:\TradingPlatform\logs\strategy-engine
